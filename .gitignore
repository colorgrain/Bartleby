# JS dependencies
node_modules/

# Rust build output (can be several GB)
src-tauri/target/

# Frontend build output
dist/

# Environment variables
.env
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~

# Tauri dev cache
.tauri/

# Sidecar binaries — platform-specific executables, not stored in git.
# Download instructions: see README or scripts/download_sidecars.sh
src-tauri/binaries/*
!src-tauri/binaries/.gitkeep
