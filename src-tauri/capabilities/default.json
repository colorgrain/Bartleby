{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Bartleby capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:webview:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "dialog:allow-confirm",
    "notification:default",
    "notification:allow-notify"
  ]
}
