{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bartleby",
  "version": "0.1.0-4",
  "identifier": "fr.bartleby.dit",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../src"
  },
  "app": {
        "windows": [
      {
        "title": "Bartleby",
        "width": 1100,
        "height": 700,
        "resizable": true,
        "center": true,
        "backgroundColor": "#ebebed"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all",
    "externalBin": [
      "binaries/ffmpeg"
    ],
    "linux": {
      "deb": {
        "depends": ["mediainfo"]
      }
    }
  }
}
